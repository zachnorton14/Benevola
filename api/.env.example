# PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname

# Environment
NODE_ENV=development            # development or production
DB_SSL=true                     # false for local dev

# Server (local dev only — not needed on Lambda)
BE_PORT=4000
ALLOWED_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=                     # generate with: openssl rand -hex 32

# Elasticsearch
ELASTICSEARCH_NODE=https://127.0.0.1:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=

# AWS S3 (local dev only — Lambda uses its execution role instead)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
